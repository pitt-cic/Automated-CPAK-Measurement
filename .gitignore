# Python
__pycache__/
*.pyc

# Virtual environments
/.venv/
/training/venv/

# IDE
/.idea/
.DS_Store

/.claude/

# Frontend (inference)
/frontend/inference/.env
/frontend/inference/dist/
/frontend/inference/node_modules/
/frontend/inference/package-lock.json

# Frontend (training) - no build artifacts, just static HTML

# Infrastructure
/infra/node_modules/
/infra/package-lock.json
/infra/dist/

# Assisted annotation checkpoints (keep folder, ignore contents)
/training/annotate/checkpoints/*
!/training/annotate/checkpoints/.gitkeep

# Dev-only files
DEVELOPER_GUIDE.md

# Models (anywhere in repo)
**/models/*
!**/models/.gitkeep

# Annotation data folders (keep folders, ignore contents)
/training/annotate/data/annotations.json
/training/annotate/data/toBeAnnotated/*
/training/annotate/data/output/*
/training/annotate/data/skipped/*
!/training/annotate/data/*/.gitkeep